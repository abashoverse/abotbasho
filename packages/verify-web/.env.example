# Public-facing config (exposed to the browser via $env/static/public).
# Self-obtain a project id at https://cloud.reown.com.
PUBLIC_WALLETCONNECT_PROJECT_ID=

# Server-only config. Never exposed to the browser. In Docker compose this
# defaults to http://indexer:42069. For local dev use http://localhost:42069.
INDEXER_URL=http://localhost:42069
