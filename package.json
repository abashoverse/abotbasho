{
  "name": "abotbasho",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:indexer": "bun --filter '@abotbasho/indexer' dev",
    "dev:discord": "bun --filter '@abotbasho/discord' dev",
    "dev:twitter": "bun --filter '@abotbasho/twitter' dev",
    "dev:seed": "bun dev/seed.ts",
    "dev:unseed": "bun dev/unseed.ts",
    "dev:seed-wrapper": "bun dev/seed-wrapper.ts",
    "dev:unseed-wrapper": "bun dev/unseed-wrapper.ts",
    "start:indexer": "bun --filter '@abotbasho/indexer' start",
    "start:discord": "bun --filter '@abotbasho/discord' start",
    "start:twitter": "bun --filter '@abotbasho/twitter' start",
    "debug:discord": "bun --filter '@abotbasho/discord' debug",
    "debug:twitter": "bun --filter '@abotbasho/twitter' debug",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
