# Secrets and per-deployment IDs only. Project behavior (poll cadence,
# IPFS gateway, RSS feed, custom messages) lives in abotbasho.config.ts.

# --- Indexer ---
# Ethereum mainnet RPC URL. Anything that supports `eth_getLogs` works:
# Alchemy, dRPC, Infura, your own node, etc.
PONDER_RPC_URL_1=https://lb.drpc.org/ogrpc?network=ethereum&dkey=YOUR_DRPC_KEY

# Internal port the indexer's API server listens on.
PONDER_PORT=42069

# --- Postgres (Docker compose only) ---
# Override these to run multiple bots on one host without volume conflicts.
#POSTGRES_USER=ponder
#POSTGRES_PASSWORD=ponder
#POSTGRES_DB=abotbasho

# --- Discord bot ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
# Default channel for all event types unless an event-specific one is set below.
DISCORD_CHANNEL_ID=
# Optional per-slot overrides. If unset, fall back to DISCORD_CHANNEL_ID.
# Each slot is registered by a plugin; the var is only read when that plugin is active.
#DISCORD_SALES_CHANNEL_ID=     # events plugin
#DISCORD_WRAPS_CHANNEL_ID=     # wrapper plugin (only if abotbasho.config.ts has a wrapper)
#DISCORD_UNWRAPS_CHANNEL_ID=   # wrapper plugin
#DISCORD_BLOG_CHANNEL_ID=      # rss plugin

# --- Twitter / X bot ---
# All four come from developer.x.com -> Keys and tokens.
# Make sure the app permissions are "Read and write" BEFORE generating Access Token + Secret.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- Shared ---
# Where bots reach the indexer's SQL-over-HTTP API (in Docker: http://indexer:42069/sql).
INDEXER_SQL_URL=http://localhost:42069/sql

# Optional override for the project config path. Defaults to abotbasho.config.ts at the
# repo root. Useful for keeping multiple configs side-by-side.
#ABOTBASHO_CONFIG_PATH=/abs/path/to/abotbasho.config.ts
