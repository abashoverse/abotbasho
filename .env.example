# Secrets and per-deployment IDs only. Project behavior (poll cadence,
# IPFS gateway, RSS feed, custom messages) lives in abotbasho.config.ts.

# --- Indexer ---
# Chain id the indexer (and bots, and verify flow) target. Default 1 (Ethereum
# mainnet). Set to 31337 for the local anvil dev path (see compose.dev.yml).
# Built-in profiles live in packages/shared/src/chain.ts; add more there.
#INDEXER_CHAIN_ID=1

# RPC URL for the indexer's chain. The numeric suffix matches INDEXER_CHAIN_ID
# (Ponder's convention: PONDER_RPC_URL_<chainId>). Anything that supports
# `eth_getLogs` works: Alchemy, dRPC, Infura, your own node, etc.
PONDER_RPC_URL_1=https://lb.drpc.org/ogrpc?network=ethereum&dkey=YOUR_DRPC_KEY

# Internal port the indexer's API server listens on.
PONDER_PORT=42069

# --- Postgres (Docker compose only) ---
# Override these to run multiple bots on one host without volume conflicts.
#POSTGRES_USER=ponder
#POSTGRES_PASSWORD=ponder
#POSTGRES_DB=abotbasho

# --- Discord bot ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
# Default channel for all event types unless an event-specific one is set below.
DISCORD_CHANNEL_ID=
# Optional per-slot overrides. If unset, fall back to DISCORD_CHANNEL_ID.
# Each slot is registered by a plugin; the var is only read when that plugin is active.
#DISCORD_SALES_CHANNEL_ID=     # events plugin
#DISCORD_WRAPS_CHANNEL_ID=     # wrapper plugin (only if abotbasho.config.ts has a wrapper)
#DISCORD_UNWRAPS_CHANNEL_ID=   # wrapper plugin
#DISCORD_BLOG_CHANNEL_ID=      # rss plugin

# --- Twitter / X bot ---
# All four come from developer.x.com -> Keys and tokens.
# Make sure the app permissions are "Read and write" BEFORE generating Access Token + Secret.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- NFT-holder verification (optional) ---
# All vars below are only read when abotbasho.config.ts has a `verify` block
# with `enabled: true`. See README for the security model.

# 32-byte hex shared between bot and indexer to authorize internal /verify
# routes. Generate with: openssl rand -hex 32
VERIFY_INTERNAL_SECRET=

# SIWE message domain. Defaults to the host of config.verify.publicUrl if unset.
#VERIFY_PUBLIC_DOMAIN=

# Optional least-privilege Postgres role with grants only on `verification.*`.
# Falls back to DATABASE_URL if unset. README has the recommended GRANTs.
#VERIFICATION_DB_URL=

# OpenSea API key. Only needed when config.verify.openseaBio is true.
#OPENSEA_API_KEY=

# WalletConnect project id for the verify-web frontend.
# Self-obtain at https://cloud.reown.com.
WALLETCONNECT_PROJECT_ID=

# Chain id exposed to the verify-web browser bundle. Must match
# INDEXER_CHAIN_ID. The wallet signs SIWE messages bound to this chain.
# Default 1.
#PUBLIC_INDEXER_CHAIN_ID=1

# Where verify-web reaches the indexer (in Docker: http://indexer:42069).
VERIFY_WEB_INDEXER_URL=http://localhost:42069

# --- Shared ---
# Where bots reach the indexer's SQL-over-HTTP API (in Docker: http://indexer:42069/sql).
INDEXER_SQL_URL=http://localhost:42069/sql

# Optional override for the project config path. Defaults to abotbasho.config.ts at the
# repo root. Useful for keeping multiple configs side-by-side.
#ABOTBASHO_CONFIG_PATH=/abs/path/to/abotbasho.config.ts
